# Public hostname served by Caddy for the UI stack.
# Example: https://scope.example.com
SCOPE_HOST=scope.example.com

# Default Scope API / WebRTC backend URL used by the browser UI.
# In same-origin deployments this can match SCOPE_HOST.
# In local dev it will often point at a separate GPU server.
# Example: https://gpu-box.example.com or https://scope.example.com
VITE_SCOPE_BASE_URL=https://scope.example.com

# Default prompt preloaded into the UI.
VITE_DEFAULT_PROMPT=A neon city at night with cinematic lighting and drifting fog
CLOUDFLARE_TURN_KEY_ID=your_cloudflare_turn_key_id
CLOUDFLARE_TURN_KEY_API_TOKEN=your_cloudflare_turn_key_api_token
HF_TOKEN=your_huggingface_token_if_needed
