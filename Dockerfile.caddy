FROM node:20-alpine AS ui-build

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY index.html tsconfig.json vite.config.ts vitest.config.ts ./
COPY src ./src
COPY public ./public

RUN npm run build

FROM caddy:2

COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=ui-build /app/dist /srv
